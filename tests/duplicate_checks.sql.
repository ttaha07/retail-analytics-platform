USE DATABASE RETAIL_ANALYTICS_DB;
USE SCHEMA GOLD;

-- FACT_SALES is order-item level, so this checks the natural sales grain.
SELECT
    'FACT_SALES' AS TABLE_NAME,
    'ORDER_ID + ORDER_ITEM_ID + PRODUCT_ID + CUSTOMER_UNIQUE_ID' AS GRAIN_CHECK,
    ORDER_ID,
    ORDER_ITEM_ID,
    PRODUCT_ID,
    CUSTOMER_UNIQUE_ID,
    COUNT(*) AS DUPLICATE_COUNT
FROM FACT_SALES
GROUP BY
    ORDER_ID,
    ORDER_ITEM_ID,
    PRODUCT_ID,
    CUSTOMER_UNIQUE_ID
HAVING COUNT(*) > 1

UNION ALL

-- DIM_CUSTOMER should have one row per physical customer.
SELECT
    'DIM_CUSTOMER' AS TABLE_NAME,
    'CUSTOMER_UNIQUE_ID' AS GRAIN_CHECK,
    NULL AS ORDER_ID,
    NULL AS ORDER_ITEM_ID,
    NULL AS PRODUCT_ID,
    CUSTOMER_UNIQUE_ID,
    COUNT(*) AS DUPLICATE_COUNT
FROM DIM_CUSTOMER
WHERE CUSTOMER_UNIQUE_ID IS NOT NULL
GROUP BY CUSTOMER_UNIQUE_ID
HAVING COUNT(*) > 1;